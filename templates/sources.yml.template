# Expedite Source Configuration
# Persists across lifecycles. Edit via /expedite:scope source configuration step.
sources:
  web:
    enabled: true
    tools: ["WebSearch", "WebFetch"]
  codebase:
    enabled: true
    tools: ["Grep", "Read", "Glob", "Bash"]
